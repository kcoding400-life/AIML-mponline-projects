# Required
GEMINI_API_KEY=

# Optional overrides (defaults shown)
GEMINI_MODEL=gemini-2.5-flash
MAX_TOKENS=1024

# Data source: URL to a PDF or an HTML SEC filing
SOURCE_URL=https://www.sec.gov/Archives/edgar/data/0001018724/000101872426000014/amzn-20260331.htm
SOURCE_LABEL=Amazon.com, Inc. Form 10-Q (Quarter Ended March 31, 2026)

# OR point at a local PDF instead of downloading (path relative to project root)
# LOCAL_SOURCE_PATH=data/source/my_report.pdf

# Retrieval / chunking tuning
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=5
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

PORT=8000
